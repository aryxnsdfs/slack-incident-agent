APP_NAME=ContextOps
PUBLIC_BASE_URL=https://api.yourdomain.com
DEMO_MODE=true

# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_REALTIME_SEARCH_METHOD=search.messages
SLACK_SEARCH_COUNT=5

# AI response synthesis. Bedrock is the production default.
AI_PROVIDER=bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
AWS_BEARER_TOKEN_BEDROCK=

# Optional OpenAI fallback if AI_PROVIDER=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# AWS
AWS_REGION=us-east-1
CLOUDWATCH_LOG_GROUP=/aws/ecs/payment-api
CLOUDWATCH_FILTER_PATTERN=ERROR ?Exception ?Timeout ?500
S3_REPORT_BUCKET=contextops-incident-reports

# Database: use PostgreSQL on RDS in production.
DATABASE_URL=postgresql+asyncpg://contextops:password@your-rds-host:5432/contextops

# MCP
CONTEXTOPS_MCP_MODE=direct
MCP_TOOL_TIMEOUT_SECONDS=20

# Reports
LOCAL_REPORT_DIR=reports
